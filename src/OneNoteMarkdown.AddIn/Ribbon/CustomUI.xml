<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="tabOneNoteMarkdown" label="Markdown" insertAfterMso="TabHome">
        <group id="grpOneNoteMarkdownImport" label="Markdown">
          <button id="btnImportMarkdown" getLabel="GetLabel" onAction="OnImportMarkdown" size="large" imageMso="FileOpen" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <button id="btnExportMarkdown" getLabel="GetLabel" onAction="OnExportMarkdown" size="large" imageMso="FileSaveAs" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <button id="btnExportMarkdownClipboard" getLabel="GetLabel" onAction="OnExportMarkdownClipboard" size="large" imageMso="Copy" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <button id="btnRenderSelection" getLabel="GetLabel" onAction="OnRenderSelection" size="large" imageMso="Paste" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <button id="btnRenderPage" getLabel="GetLabel" onAction="OnRenderPage" size="large" imageMso="ReviewAcceptChange" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <toggleButton id="btnToggleLivePreview" getLabel="GetLabel" onAction="OnToggleLivePreview" getPressed="GetLivePreviewPressed" size="large" imageMso="Refresh" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <button id="btnMarkdownSettings" getLabel="GetLabel" onAction="OnSettings" size="large" imageMso="FileSave" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
          <button id="btnMarkdownHelp" getLabel="GetLabel" onAction="OnHelp" size="large" imageMso="Help" getScreentip="GetScreentip" getSupertip="GetSupertip"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
